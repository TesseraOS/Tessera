{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(pnpm install)",
      "Bash(pnpm -w typecheck)",
      "Bash(pnpm -w lint)",
      "Bash(pnpm -w format:check)",
      "Bash(pnpm -w test)",
      "Bash(pnpm -w test:e2e)",
      "Bash(pnpm -w build)",
      "Bash(node scripts/verify-state.mjs)",
      "Bash(bash scripts/init.sh)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./.env.local)",
      "Read(./**/.env.local)",
      "Read(./.env.development)",
      "Read(./.env.production)",
      "Read(./.env.test)",
      "Read(./.env.staging)",
      "Read(./.env.*.local)",
      "Read(./**/.env.*.local)",
      "Read(./.claude/settings.local.json)"
    ]
  }
}
