# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file for the Tessera monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

# Markdown: trailing whitespace can be a hard line break — don't strip it.
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Go-style / Makefiles require tabs.
[Makefile]
indent_style = tab

# Windows-only scripts keep CRLF.
[*.{ps1,psm1,psd1,cmd,bat}]
end_of_line = crlf

# POSIX shell scripts must stay LF even on Windows checkouts.
[*.sh]
end_of_line = lf

[*.{yml,yaml,json,jsonc}]
indent_size = 2
