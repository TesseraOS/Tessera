# Tessera environment (EXAMPLE). Copy to `.env` (git-ignored) and fill values.
# Local mode needs NO external services or API keys. Vars under "self-hosted / cloud"
# apply when TESSERA_PROFILE != local. The web app has its own apps/web/.env.example
# (NEXT_PUBLIC_API_BASE_URL). Config env-var mapping: packages/config/src/load.ts.

# --- Deployment profile: local | self-hosted | cloud (ADR-0003) ---
TESSERA_PROFILE=local

# --- Runtime / server (apps/server) ---
NODE_ENV=development
# HOST=127.0.0.1
# PORT=3000
# TESSERA_ENV=development
# TESSERA_LOG_LEVEL=info            # trace | debug | info | warn | error
# TESSERA_TELEMETRY=0               # 1 enables OpenTelemetry traces/metrics (off by default)

# --- Local storage paths (local profile; defaults are sensible) ---
# TESSERA_SQLITE_PATH=./.data/tessera.sqlite
# TESSERA_VECTOR_PATH=./.data/vectors.sqlite
# TESSERA_BLOB_ROOT=./.data/blobs

# --- Embeddings (local default = Transformers.js, no key) ---
# TESSERA_EMBEDDINGS_PROVIDER=transformers      # transformers | ollama | fake
# TESSERA_EMBEDDINGS_MODEL=Xenova/all-MiniLM-L6-v2
# TESSERA_EMBEDDINGS_DIMENSION=384
# TESSERA_OLLAMA_URL=http://127.0.0.1:11434     # only for the ollama provider

# --- Context compiler budgets ---
# TESSERA_CONTEXT_BUDGET=8000
# TESSERA_RETRIEVAL_LIMIT=20

# --- Auth (F-025 RBAC / F-034 wiring) ---
# TESSERA_AUTH_MODE=none            # none = zero-auth local (full access) | token = Bearer required
# TESSERA_AUTH_TENANT=default       # tenant assigned to the local principal in "none" mode
# TESSERA_AUTH_QUOTA_ENABLED=0      # 1 enables per-principal MCP quotas (F-026)
# TESSERA_AUTH_QUOTA_LIMIT=120      # max tool calls per principal per window
# TESSERA_AUTH_QUOTA_WINDOW_MS=60000
# Token mode: issue tokens with `pnpm --filter @tessera/server exec tessera-token --roles owner` (secret shown once).
# TESSERA_AUTH_MODE (above) may be `oidc` — verify JWTs from an external OIDC IdP (F-036):
# TESSERA_AUTH_OIDC_ISSUER=https://idp.example.com/realms/tessera   # required for oidc
# TESSERA_AUTH_OIDC_AUDIENCE=tessera-api                            # required for oidc
# TESSERA_AUTH_OIDC_JWKS_URI=                                       # default: <issuer>/.well-known/jwks.json
# TESSERA_AUTH_OIDC_ROLES_CLAIM=roles                              # JWT claim carrying RBAC roles
# TESSERA_AUTH_OIDC_TENANT_CLAIM=tenant_id                         # JWT claim carrying the tenant/org id

# --- Secrets provider (packages/config/src/secrets) ---
# TESSERA_SECRETS_PROVIDER=env                  # env | file
# TESSERA_SECRETS_FILE=./secrets.json           # for the "file" provider (a JSON map)
# TESSERA_SECRET_PREFIX=TESSERA_SECRET_         # env provider reads process.env under this prefix

# --- Billing (F-030; open-core — local/free by default, no external service) ---
# TESSERA_BILLING_PROVIDER=none     # none = local/free (OSS) | dodo = Dodo Payments (cloud)
# TESSERA_BILLING_DODO_BASE_URL=https://api.dodopayments.com   # override for sandbox
# Dodo secrets go through the SecretsProvider (prefixed for the "env" provider):
# TESSERA_SECRET_BILLING_DODO_API_KEY=
# TESSERA_SECRET_BILLING_DODO_WEBHOOK_SECRET=

# --- Self-hosted / cloud only (leave unset for local) ---
# Postgres + pgvector (F-023; see docker-compose.yml). Required for the self-hosted/cloud profiles.
# DATABASE_URL=postgres://tessera:tessera@127.0.0.1:5432/tessera
# REDIS_URL=
# OBJECT_STORE_ENDPOINT=
# OBJECT_STORE_BUCKET=
# OIDC_ISSUER_URL=

# --- Optional hosted AI providers (local uses Transformers.js, no key needed) ---
# OPENAI_API_KEY=
# COHERE_API_KEY=

# --- Local integration-test guards (DEV / CI only — NOT for production) ---
# TESSERA_TEST_POSTGRES=1           # run the Postgres/pgvector conformance (needs DATABASE_URL)
# TESSERA_TEST_TRANSFORMERS=1       # run the real Transformers.js embeddings test
# TESSERA_TEST_OLLAMA=1             # run the Ollama embeddings test
# TESSERA_TEST_GITHUB=1             # run the live GitHub connector smoke test
# GITHUB_TOKEN=                     # GitHub token (live GitHub test; also the production GitHub connector)
# GITHUB_TEST_OWNER=octocat
# GITHUB_TEST_REPO=Hello-World
