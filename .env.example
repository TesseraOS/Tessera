# Tessera environment (EXAMPLE). Copy to .env (git-ignored) and fill values.
# Local mode needs NO external services or API keys; the vars below are for the
# self-hosted / cloud profiles (selected via TESSERA_PROFILE; see ADR-0003).

# Deployment profile: local | self-hosted | cloud
TESSERA_PROFILE=local

# Runtime
NODE_ENV=development
# PORT=3000
# LOG_LEVEL=info

# --- Cloud / self-hosted only (leave unset for local) ---
# DATABASE_URL=
# REDIS_URL=
# OBJECT_STORE_ENDPOINT=
# OBJECT_STORE_BUCKET=
# OIDC_ISSUER_URL=

# --- Optional hosted AI providers (local uses Transformers.js, no key needed) ---
# OPENAI_API_KEY=
# COHERE_API_KEY=
