{
  "name": "@tessera/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/core.d.ts",
      "import": "./dist/auth/core.js"
    },
    "./projects": {
      "types": "./dist/projects/index.d.ts",
      "import": "./dist/projects/index.js"
    },
    "./stats": {
      "types": "./dist/stats/core.d.ts",
      "import": "./dist/stats/core.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.5.1",
    "@tessera/billing": "workspace:*",
    "@tessera/context-compiler": "workspace:*",
    "@tessera/core": "workspace:*",
    "@tessera/ingestion": "workspace:*",
    "@tessera/knowledge-graph": "workspace:*",
    "@tessera/memory": "workspace:*",
    "@tessera/retrieval": "workspace:*",
    "fastify": "^5.5.0",
    "fastify-type-provider-zod": "^5.1.0",
    "jose": "^6.2.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tessera/storage": "workspace:*"
  }
}
