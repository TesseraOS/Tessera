# apps/docs — public documentation site (ADR-0035). No secrets: this surface holds no
# credentials and never calls the authenticated API (NFR-17).

# Canonical URL of this docs site (used for metadata, sitemap, llms.txt links).
NEXT_PUBLIC_DOCS_URL=http://localhost:3003

# Marketing site (apex) — cross-surface links.
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Dashboard — cross-surface links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public repository. UNSET until it exists (open-core publish lands with F-059) — when
# set, the docs chrome grows its GitHub icon link; the site never fabricates the URL.
# NEXT_PUBLIC_GITHUB_URL=
