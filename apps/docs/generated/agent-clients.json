{
  "$source": "apps/cli/src/mcp-clients.ts MCP_CLIENTS + renderMcpClientConfig — regenerate with `pnpm --filter @tessera/docs generate`",
  "configPlaceholder": "/path/to/your/project/tessera.config.json",
  "cliBinPlaceholder": "/path/to/tessera/apps/cli/dist/bin/tessera.js",
  "clients": [
    {
      "id": "claude-code",
      "label": "Claude Code",
      "file": ".mcp.json (project) or ~/.claude.json",
      "format": "json-mcpservers",
      "snippetNpx": "{\n  \"mcpServers\": {\n    \"tessera\": {\n      \"command\": \"npx\",\n      \"args\": [\n        \"-y\",\n        \"@tessera/cli\",\n        \"mcp\",\n        \"--config\",\n        \"/path/to/your/project/tessera.config.json\"\n      ]\n    }\n  }\n}",
      "snippetLocal": "{\n  \"mcpServers\": {\n    \"tessera\": {\n      \"command\": \"node\",\n      \"args\": [\n        \"/path/to/tessera/apps/cli/dist/bin/tessera.js\",\n        \"mcp\",\n        \"--config\",\n        \"/path/to/your/project/tessera.config.json\"\n      ]\n    }\n  }\n}"
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "file": ".cursor/mcp.json (project) or ~/.cursor/mcp.json",
      "format": "json-mcpservers",
