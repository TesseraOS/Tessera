      "snippetNpx": "[mcp_servers.tessera]\ncommand = \"npx\"\nargs = [\"-y\", \"@tessera/cli\", \"mcp\", \"--config\", \"/path/to/your/project/tessera.config.json\"]",
      "snippetLocal": "[mcp_servers.tessera]\ncommand = \"node\"\nargs = [\"/path/to/tessera/apps/cli/dist/bin/tessera.js\", \"mcp\", \"--config\", \"/path/to/your/project/tessera.config.json\"]"
