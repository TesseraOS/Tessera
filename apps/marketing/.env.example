# @tessera/marketing environment (EXAMPLE). Copy to `.env.local` to override.
# The final TLD is undecided (ADR-0035) — every cross-surface URL is env-driven; the
# design-lint gate rejects hardcoded tessera.* domains in source.

# Absolute origin of THIS site (drives metadataBase, sitemap.xml, robots.txt, OG URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# The dashboard (CTAs: "Start free", "Sign in").
NEXT_PUBLIC_APP_URL=http://localhost:3100

# The docs site (F-053; links render regardless, target ships later).
NEXT_PUBLIC_DOCS_URL=http://localhost:3003
